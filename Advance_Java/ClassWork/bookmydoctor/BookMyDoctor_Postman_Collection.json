{
  "info": {
    "name": "BookMyDoctor API",
    "_postman_id": "bookmydoctor-collection-v1",
    "description": "Doctor Appointment Booking System - REST API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "user_token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phoneNumber\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.data && resp.data.token) {",
                  "  pm.collectionVariables.set('user_token', resp.data.token);",
                  "  console.log('User token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "if (resp.data && resp.data.token) {",
                  "  pm.collectionVariables.set('admin_token', resp.data.token);",
                  "  console.log('Admin token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Add Doctor (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/doctors", "host": ["{{base_url}}"], "path": ["api","doctors"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorName\": \"Dr. Priya Sharma\",\n  \"specialization\": \"Cardiology\",\n  \"hospitalName\": \"City Heart Hospital\",\n  \"experienceYears\": 10,\n  \"consultationFee\": 500.00,\n  \"availableDays\": \"Monday, Wednesday, Friday\",\n  \"availableTime\": \"10:00 AM - 2:00 PM\"\n}"
            }
          }
        },
        {
          "name": "Update Doctor (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/doctors/1", "host": ["{{base_url}}"], "path": ["api","doctors","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorName\": \"Dr. Priya Sharma\",\n  \"specialization\": \"Cardiology\",\n  \"hospitalName\": \"Apollo Hospital\",\n  \"experienceYears\": 12,\n  \"consultationFee\": 600.00,\n  \"availableDays\": \"Monday, Tuesday, Thursday\",\n  \"availableTime\": \"9:00 AM - 1:00 PM\"\n}"
            }
          }
        },
        {
          "name": "Delete Doctor (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/doctors/1", "host": ["{{base_url}}"], "path": ["api","doctors","1"] }
          }
        },
        {
          "name": "Get All Doctors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/doctors", "host": ["{{base_url}}"], "path": ["api","doctors"] }
          }
        },
        {
          "name": "Get Doctor By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/doctors/1", "host": ["{{base_url}}"], "path": ["api","doctors","1"] }
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Book Appointment (User)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/appointments", "host": ["{{base_url}}"], "path": ["api","appointments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": 1,\n  \"appointmentDate\": \"2026-03-20\",\n  \"appointmentTime\": \"10:30:00\"\n}"
            }
          }
        },
        {
          "name": "My Appointments (User)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/appointments/my", "host": ["{{base_url}}"], "path": ["api","appointments","my"] }
          }
        },
        {
          "name": "Cancel Appointment (User)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/appointments/1", "host": ["{{base_url}}"], "path": ["api","appointments","1"] }
          }
        },
        {
          "name": "All Appointments (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/appointments", "host": ["{{base_url}}"], "path": ["api","appointments"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api","users"] }
          }
        }
      ]
    }
  ]
}
